# n8n Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it's in .gitignore

# ============================================================
# GOOGLE OAUTH2 (Sheets + Drive)
# Get from: https://console.cloud.google.com/
# ============================================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google Drive — ID of the folder containing your videos
# From URL: drive.google.com/drive/folders/[THIS_IS_THE_ID]
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Google Sheets — ID of the tracker spreadsheet
# From URL: docs.google.com/spreadsheets/d/[THIS_IS_THE_ID]
TRACKER_SHEET_ID=your_google_sheets_tracker_id_here

# ============================================================
# YOUTUBE API
# Get from: https://console.cloud.google.com/
# Enable: YouTube Data API v3
# ============================================================
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here

# ============================================================
# INSTAGRAM GRAPH API
# Requirements:
#   - Facebook Business Account
#   - Instagram Business/Creator Account
#   - Connected to Facebook Page
# Get from: https://developers.facebook.com/
# ============================================================
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id_here
# Long-lived access token (valid for 60 days, must rotate)
INSTAGRAM_ACCESS_TOKEN=your_instagram_long_lived_access_token_here

# ============================================================
# WHATSAPP — CallMeBot (FREE)
# Setup: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# Steps:
#   1. Add +34 644 59 35 89 to your WhatsApp contacts as "CallMeBot"
#   2. Send this message: "I allow callmebot to send me messages"
#   3. You'll receive your API key in ~2 minutes
# ============================================================
# Your WhatsApp number with country code (no + sign, no spaces)
# Example: 919876543210 (91 = India country code)
WHATSAPP_PHONE=919876543210
CALLMEBOT_API_KEY=your_callmebot_api_key_here

# ============================================================
# N8N CONFIGURATION
# ============================================================
N8N_URL=http://localhost:5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_secure_password_here
N8N_ENCRYPTION_KEY=your_32_char_encryption_key_here

# ============================================================
# OPTIONAL: TWILIO WHATSAPP (ALTERNATIVE TO CALLMEBOT)
# Better for production — no message limits
# Get from: https://www.twilio.com/
# ============================================================
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_WHATSAPP_TO=whatsapp:+919876543210
